{
  "name": "@multiplayer-app/cli",
  "version": "1.3.36",
  "description": "Multiplayer CLI",
  "main": "dist/index.js",
  "bin": {
    "multiplayer": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target bun --format esm --sourcemap=none && rm -f dist/index.js.map",
    "start": "bun dist/index.js",
    "dev": "bun src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.73",
    "@anthropic-ai/sdk": "^0.78.0",
    "@opentui/core": "0.1.93",
    "@opentui/react": "0.1.93",
    "commander": "14.0.3",
    "dotenv": "16.0.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.3.3",
    "openai": "6.33.0",
    "react": "19.2.4",
    "simple-git": "3.33.0",
    "socket.io-client": "4.8.3",
    "superagent": "10.3.0"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^8.1.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/superagent": "^8.1.9",
    "typescript": "6.0.2"
  }
}
