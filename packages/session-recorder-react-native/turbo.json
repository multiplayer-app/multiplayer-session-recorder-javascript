{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "package.json",
        "tsconfig*.json",
        "babel.config.js"
      ],
      "outputs": ["lib/**"]
    },
    "build:android": {
      "env": [
        "ANDROID_HOME",
        "ORG_GRADLE_PROJECT_newArchEnabled"
      ],
      "inputs": [
        "package.json",
        "android",
        "!android/build",
        "src/*.ts",
        "src/*.tsx"
      ],
      "outputs": []
    },
    "build:ios": {
      "env": [
        "RCT_NEW_ARCH_ENABLED",
        "RCT_USE_RN_DEP",
        "RCT_USE_PREBUILT_RNCORE"
      ],
      "inputs": [
        "package.json",
        "*.podspec",
        "ios",
        "src/*.ts",
        "src/*.tsx"
      ],
      "outputs": []
    }
  }
}
